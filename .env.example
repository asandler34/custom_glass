# Copy to `.env.local` for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables for production.
# Public contact + lead inbox: free Gmail (`BUSINESS.email`). Form sends via Resend — see docs/EMAIL_AND_GBP_SETUP.md.

# Public: canonical site URL (metadata, sitemap, JSON-LD). Must match the URL you use on Google Business Profile.
NEXT_PUBLIC_SITE_URL=https://www.exquisitecustomglass.com

# Contact API (Resend): https://resend.com — create API key after verifying your sending domain in Resend.
RESEND_API_KEY=

# Where lead notifications are delivered (Resend `to:`). Can be any inbox, e.g. Gmail.
CONTACT_TO_EMAIL=exquisitecustomglass@gmail.com

# Sender on lead emails (Resend `from:`). Use any Resend-verified address on your domain — no paid mailbox required,
# only DNS verification in Resend. Do not use @gmail.com here.
CONTACT_FROM_EMAIL=no-reply@exquisitecustomglass.com
