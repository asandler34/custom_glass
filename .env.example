# Copy to `.env.local` for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables for production.
# Mailbox: Google Workspace on domain at GoDaddy — see docs/EMAIL_AND_GBP_SETUP.md for MX/DNS + Resend SPF.

# Public: canonical site URL (metadata, sitemap, JSON-LD). Must match the URL you use on Google Business Profile.
NEXT_PUBLIC_SITE_URL=https://www.exquisitecustomglass.com

# Contact API (Resend): https://resend.com — create API key after verifying your sending domain in Resend.
RESEND_API_KEY=

# Where lead notifications are delivered (use your live inbox once hello@ exists).
CONTACT_TO_EMAIL=hello@exquisitecustomglass.com

# Sender shown on outbound lead emails — must be a domain/address Resend has verified for your domain.
# Often `hello@…` or `no-reply@…` on the same domain as the site.
CONTACT_FROM_EMAIL=hello@exquisitecustomglass.com
